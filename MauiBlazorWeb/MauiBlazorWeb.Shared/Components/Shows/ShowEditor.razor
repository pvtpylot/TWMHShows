@using MauiBlazorWeb.Shared.Models.DTOs

<EditForm Model="@Model" OnValidSubmit="@OnValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="card mb-3">
        <div class="card-header"><strong>Show Details</strong></div>
        <div class="card-body">
            <div class="row gy-3">
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="Model.Name" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Status</label>
                    <InputSelect class="form-select" @bind-Value="Model.Status">
                        @foreach (var s in Statuses)
                        {
                            <option value="@s">@s</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-12">
                    <label class="form-label">Description</label>
                    <InputTextArea class="form-control" rows="2" @bind-Value="Model.Description" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Start Date</label>
                    <InputDate class="form-control" @bind-Value="Model.ShowDate" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">End Date</label>
                    <InputDate class="form-control" @bind-Value="Model.EndDate" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Max Entries Per User</label>
                    <InputNumber class="form-control" @bind-Value="Model.MaxEntriesPerUser" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Show Type</label>
                    <InputSelect class="form-select" @bind-Value="Model.ShowType">
                        @foreach (var s in ShowTypes)
                        {
                            <option value="@s">@s</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Show Format</label>
                    <InputSelect class="form-select" @bind-Value="Model.ShowFormat">
                        @foreach (var s in ShowFormats)
                        {
                            <option value="@s">@s</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="Model.IsPrivate" id="chkPrivate" />
                        <label class="form-check-label" for="chkPrivate">Private</label>
                    </div>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="Model.AllowMemberOnlyEntries" id="chkMembersOnly" />
                        <label class="form-check-label" for="chkMembersOnly">Members Only</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Entry Deadline</label>
                    <InputDate class="form-control" @bind-Value="Model.EntryDeadline" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Judging Deadline</label>
                    <InputDate class="form-control" @bind-Value="Model.JudgingDeadline" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Results Publish</label>
                    <InputDate class="form-control" @bind-Value="Model.ResultsPublishedAt" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="Model.IsNanQualifying" id="chkNan" />
                        <label class="form-check-label" for="chkNan">NAN Qualifying</label>
                    </div>
                </div>
                <div class="col-12" hidden="@(!Model.IsNanQualifying)">
                    <label class="form-label">NAMHSA Guidelines / Notes</label>
                    <InputTextArea class="form-control" rows="2" @bind-Value="Model.NamhsaGuidelines" />
                </div>
                <div class="col-12">
                    <label class="form-label">Additional Metadata (JSON)</label>
                    <InputTextArea class="form-control font-monospace" rows="3" @bind-Value="Model.AdditionalMetadata" />
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Divisions & Classes</strong>
            <div class="btn-group">
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => AddDivisionTemplate("Halter")">Add Halter</button>
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => AddDivisionTemplate("Performance")">Add Performance</button>
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => AddDivisionTemplate("Collectibility")">Add Collectibility</button>
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => AddDivisionTemplate("Workmanship")">Add Workmanship</button>
                <button type="button" class="btn btn-sm btn-secondary" @onclick="AddEmptyDivision">Add Empty Division</button>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Divisions.Count == 0)
            {
                <div class="text-muted small">No divisions yet. Use the buttons above to add.</div>
            }
            else
            {
                @foreach (var d in Model.Divisions.OrderBy(x => x.SortOrder).ToList())
                {
                    <DivisionEditor Division="d" OnRemoveDivision="RemoveDivision" />
                }
            }
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-outline-secondary" @onclick="() => OnCancel.InvokeAsync()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Show</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired] public ShowDto Model { get; set; } = default!;
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private static readonly string[] Statuses = new[] { "Upcoming", "InProgress", "Completed", "Cancelled" };
    private static readonly string[] ShowTypes = new[] { "LiveShow", "PhotoShow" };
    private static readonly string[] ShowFormats = new[] { "Regular", "NanQualifying", "Championship", "Specialty" };

    private async Task OnValidSubmit()
    {
        await OnSave.InvokeAsync();
    }

    private void AddEmptyDivision()
    {
        var nextOrder = Model.Divisions.Count > 0 ? Model.Divisions.Max(d => d.SortOrder) + 1 : 1;
        Model.Divisions.Add(new DivisionDto
        {
            Id = string.Empty,
            Name = "New Division",
            Description = string.Empty,
            DivisionType = "Halter",
            SortOrder = nextOrder,
            ShowId = int.TryParse(Model.Id, out var sid) ? sid : 0,
            ShowClasses = new List<ShowClassDto>()
        });
    }

    private void AddDivisionTemplate(string type)
    {
        var nextOrder = Model.Divisions.Count > 0 ? Model.Divisions.Max(d => d.SortOrder) + 1 : 1;
        var division = new DivisionDto
        {
            Id = string.Empty,
            Name = type,
            Description = $"{type} Division",
            DivisionType = type,
            SortOrder = nextOrder,
            ShowId = int.TryParse(Model.Id, out var sid) ? sid : 0,
            ShowClasses = new List<ShowClassDto>()
        };

        // Optional: seed a few common classes as a starting point
        if (type.Equals("Halter", StringComparison.OrdinalIgnoreCase))
        {
            division.ShowClasses.AddRange(new[]
            {
                NewClass("Sport Breeds"), NewClass("Light Breeds"), NewClass("Draft Breeds"),
                NewClass("Pony Breeds"), NewClass("Stock Breeds"), NewClass("Other Breeds")
            });
        }
        else if (type.Equals("Performance", StringComparison.OrdinalIgnoreCase))
        {
            division.ShowClasses.AddRange(new[]
            {
                NewClass("Hunter/Jumper"), NewClass("Dressage"), NewClass("English Pleasure"),
                NewClass("English Trail"), NewClass("Reining"), NewClass("Western Pleasure"),
                NewClass("Barrel Racing"), NewClass("Western Trail"), NewClass("Costume"),
                NewClass("Parade"), NewClass("Harness"), NewClass("Scene/Setup")
            });
        }

        Model.Divisions.Add(division);

        ShowClassDto NewClass(string name) => new()
        {
            Id = string.Empty,
            Name = name,
            Description = string.Empty,
            ClassNumber = division.ShowClasses.Count + 1,
            SortOrder = division.ShowClasses.Count + 1,
            DivisionId = long.TryParse(division.Id, out var did) ? did : 0,
            DivisionName = type,
            ShowId = division.ShowId,
            ShowName = Model.Name
        };
    }

    private Task RemoveDivision(DivisionDto division)
    {
        Model.Divisions.Remove(division);
        return Task.CompletedTask;
    }
}