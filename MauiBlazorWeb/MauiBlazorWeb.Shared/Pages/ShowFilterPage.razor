@page "/shows"
@using MauiBlazorWeb.Shared.Models.DTOs
@using MauiBlazorWeb.Shared.Services
@using MauiBlazorWeb.Shared.Models
@using Microsoft.AspNetCore.Authorization
@inject IShowService ShowService
@attribute [Authorize(Roles = $"{ApplicationRoles.User},{ApplicationRoles.TrialUser},{ApplicationRoles.Admin}")]

<PageTitle>Shows</PageTitle>

<div class="container">
    <h1>Available Shows</h1>
    <p class="lead">Browse and enter upcoming model horse shows</p>

    <!-- Filter Controls -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <label class="form-label">Show Type</label>
                    <select class="form-select" @bind="filterShowType" @oninput="FilterShows">
                        <option value="">All Types</option>
                        <option value="LiveShow">Live Show</option>
                        <option value="PhotoShow">Photo Show</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Show Format</label>
                    <select class="form-select" @bind="filterShowFormat" @oninput="FilterShows">
                        <option value="">All Formats</option>
                        <option value="Regular">Regular</option>
                        <option value="NanQualifying">NAN Qualifying</option>
                        <option value="Championship">Championship</option>
                        <option value="Specialty">Specialty</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select class="form-select" @bind="filterStatus" @oninput="FilterShows">
                        <option value="">All Status</option>
                        <option value="Upcoming">Upcoming</option>
                        <option value="InProgress">In Progress</option>
                        <option value="Completed">Completed</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" id="nanOnly" @bind="filterNanOnly" @oninput="FilterShows">
                        <label class="form-check-label" for="nanOnly">
                            NAN Qualifying Only
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (loading)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (filteredShows == null || !filteredShows.Any())
    {
        <div class="alert alert-info" role="alert">
            @if (allShows?.Any() == true)
            {
                <p>No shows match your current filter criteria.</p>
            }
            else
            {
                <p>No shows are currently available. Check back later for upcoming shows!</p>
            }
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var show in filteredShows.OrderBy(s => s.ShowDate))
            {
                <div class="col">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-start">
                            <h5 class="card-title mb-0">@show.Name</h5>
                            <div class="d-flex flex-column align-items-end">
                                <span class="badge @GetStatusBadgeClass(show.Status) mb-1">
                                    @show.Status
                                </span>
                                @if (show.IsNanQualifying)
                                {
                                    <span class="badge bg-warning text-dark">NAN</span>
                                }
                            </div>
                        </div>
                        
                        <div class="card-body d-flex flex-column">
                            @if (!string.IsNullOrEmpty(show.Description))
                            {
                                <p class="card-text">
                                    @(show.Description.Length > 100 ? show.Description.Substring(0, 100) + "..." : show.Description)
                                </p>
                            }
                            
                            <div class="mb-3">
                                <div class="row text-sm">
                                    <div class="col-6">
                                        <strong>Show Date:</strong><br>
                                        @show.ShowDate.ToString("MMM dd, yyyy")
                                        @if (show.EndDate.HasValue && show.EndDate != show.ShowDate)
                                        {
                                            <text> - @show.EndDate.Value.ToString("MMM dd")</text>
                                        }
                                    </div>
                                    <div class="col-6">
                                        <strong>Type:</strong><br>
                                        @show.ShowType
                                    </div>
                                </div>
                                
                                <div class="row text-sm mt-2">
                                    <div class="col-6">
                                        <strong>Format:</strong><br>
                                        @show.ShowFormat
                                    </div>
                                    <div class="col-6">
                                        <strong>Judge:</strong><br>
                                        @(string.IsNullOrEmpty(show.JudgeName) ? "TBA" : show.JudgeName)
                                    </div>
                                </div>
                                
                                @if (show.EntryDeadline.HasValue)
                                {
                                    <div class="row text-sm mt-2">
                                        <div class="col-12">
                                            <strong>Entry Deadline:</strong><br>
                                            <span class="@(show.EntryDeadline < DateTime.Now ? "text-danger" : (show.EntryDeadline < DateTime.Now.AddDays(7) ? "text-warning" : ""))">
                                                @show.EntryDeadline.Value.ToString("MMM dd, yyyy")
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                            
                            <!-- Divisions Summary -->
                            @if (show.Divisions.Any())
                            {
                                <div class="mb-3">
                                    <strong>Divisions (@show.Divisions.Count):</strong>
                                    <div class="d-flex flex-wrap gap-1 mt-1">
                                        @foreach (var division in show.Divisions.Take(4))
                                        {
                                            <span class="badge bg-secondary">@division.DivisionType</span>
                                        }
                                        @if (show.Divisions.Count > 4)
                                        {
                                            <span class="badge bg-light text-dark">+@(show.Divisions.Count - 4) more</span>
                                        }
                                    </div>
                                </div>
                            }
                            
                            <!-- Entry Information -->
                            <div class="text-sm text-muted mb-3">
                                <div>Max entries per user: @show.MaxEntriesPerUser</div>
                                @if (show.AllowMemberOnlyEntries)
                                {
                                    <div>Members only</div>
                                }
                                @if (show.IsPrivate)
                                {
                                    <div><i class="oi oi-lock-locked"></i> Private show</div>
                                }
                            </div>
                            
                            <div class="mt-auto">
                                <a href="/show-details/@show.Id" class="btn btn-primary btn-sm">
                                    <i class="oi oi-eye"></i> View Details
                                </a>
                                @if (show.Status == "Upcoming" && (!show.EntryDeadline.HasValue || show.EntryDeadline > DateTime.Now))
                                {
                                    <a href="/enter-show/@show.Id" class="btn btn-success btn-sm ms-2">
                                        <i class="oi oi-plus"></i> Enter Show
                                    </a>
                                }
                            </div>
                        </div>
                        
                        <div class="card-footer text-muted">
                            <small>
                                Show Holder: @show.ShowHolderName<br>
                                @show.Divisions.Sum(d => d.ShowClasses.Count) classes total
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ShowDto>? allShows;
    private List<ShowDto>? filteredShows;
    private bool loading = true;
    
    // Filter properties
    private string filterShowType = "";
    private string filterShowFormat = "";
    private string filterStatus = "";
    private bool filterNanOnly = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadShows();
    }

    private async Task LoadShows()
    {
        loading = true;
        try
        {
            allShows = (await ShowService.GetAllShowsAsync())
                .Where(s => !s.IsPrivate) // Only show public shows
                .ToList();
            
            FilterShows();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading shows: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private void FilterShows()
    {
        if (allShows == null)
            return;

        filteredShows = allShows.Where(s =>
            (string.IsNullOrEmpty(filterShowType) || s.ShowType == filterShowType) &&
            (string.IsNullOrEmpty(filterShowFormat) || s.ShowFormat == filterShowFormat) &&
            (string.IsNullOrEmpty(filterStatus) || s.Status == filterStatus) &&
            (!filterNanOnly || s.IsNanQualifying)
        ).ToList();
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Upcoming" => "bg-info",
            "InProgress" => "bg-warning text-dark",
            "Completed" => "bg-success",
            "Cancelled" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
